<?xml version="1.0"?>
<robot name="my_arm_with_gripper">

  <material name="blue">
    <color rgba="0.0 0.0 0.8 1.0"/>
  </material>
  <material name="grey">
    <color rgba="0.7 0.7 0.7 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>
  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>
  <material name="gripper_material">
    <color rgba="0.9 0.9 0.1 1.0"/>
  </material>

  <link name="base_link">
    <visual>
      <geometry>
        <!-- 8cm x 8cm x 5cm -->
        <box size="0.08 0.08 0.05"/>
      </geometry>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.08 0.08 0.05"/>
      </geometry>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
    </collision>
  </link>

  <joint name="shoulder_pan_joint" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.05" upper="3.05" effort="100" velocity="1.0"/>
  </joint>

  <link name="shoulder_link">
    <visual>
      <geometry>
        <!-- diameter 5cm, height 1cm -->
        <cylinder length="0.01" radius="0.025"/>
      </geometry>
      <origin xyz="0 0 0.005" rpy="0 0 0"/>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.01" radius="0.025"/>
      </geometry>
      <origin xyz="0 0 0.005" rpy="0 0 0"/>
    </collision>
  </link>

  <joint name="shoulder_lift_joint" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <!-- place joint at the top of shoulder_link so links are not floating -->
    <origin xyz="0 0 0.01" rpy="0 0 0"/>
    <!-- pitch (up/down) -->
    <axis xyz="1 0 0"/>
    <limit lower="-1.75" upper="1.05" effort="100" velocity="1.0"/>
  </joint>

  <link name="upper_arm_link">
    <visual>
      <geometry>
        <!-- length 8cm, width 5.5cm, height 3cm -->
        <!-- stand up: extend along +Z -->
        <box size="0.055 0.03 0.08"/>
      </geometry>
      <!-- start at joint and extend along +Z by half length -->
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.055 0.03 0.08"/>
      </geometry>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
    </collision>
  </link>

  <joint name="elbow_joint" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <!-- match upper_arm_link length (8cm) -->
    <origin xyz="0 0 0.08" rpy="0 0 0"/>
    <!-- pitch (up/down) -->
    <axis xyz="1 0 0"/>
    <limit lower="-1.10" upper="1.05" effort="100" velocity="1.0"/>
  </joint>

  <link name="forearm_link">
    <visual>
      <geometry>
        <!-- length 8cm, width 5.5cm, height 3cm -->
        <box size="0.055 0.03 0.08"/>
      </geometry>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <material name="white"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.055 0.03 0.08"/>
      </geometry>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
    </collision>
  </link>

  <joint name="wrist_1_joint" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_1_link"/>
    <!-- match forearm_link length (8cm) -->
    <origin xyz="0 0 0.08" rpy="0 0 0"/>
    <!-- pitch (up/down) -->
    <axis xyz="1 0 0"/>
    <limit lower="-1.10" upper="1.60" effort="50" velocity="1.0"/>
  </joint>

  <link name="wrist_1_link">
    <visual>
      <geometry>
        <!-- length 5cm, width 5.5cm, height 3cm -->
        <box size="0.055 0.03 0.05"/>
      </geometry>
      <!-- match length 5cm -->
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.055 0.03 0.05"/>
      </geometry>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
    </collision>
  </link>

  <joint name="wrist_2_joint" type="revolute">
    <parent link="wrist_1_link"/>
    <child link="wrist_2_link"/>
    <!-- match wrist_1_link length (5cm), keep chain vertical along +Z -->
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <!-- yaw (horizontal rotation) -->
    <axis xyz="0 0 1"/>
    <limit lower="-1.05" upper="2.05" effort="50" velocity="1.0"/>
  </joint>

  <link name="wrist_2_link">
    <visual>
      <geometry>
        <!-- diameter 2cm, height 1cm -->
        <cylinder length="0.01" radius="0.01"/>
      </geometry>
      <origin xyz="0 0 0.005" rpy="0 0 0"/>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.01" radius="0.01"/>
      </geometry>
      <origin xyz="0 0 0.005" rpy="0 0 0"/>
    </collision>
  </link>

  <joint name="wrist_2_to_gripper_base_joint" type="fixed">
    <parent link="wrist_2_link"/>
    <!-- match wrist_2_link height (1cm) -->
    <origin xyz="0 0 0.01" rpy="0 0 0"/>
    <child link="gripper_base_link"/>
  </joint>

  <link name="gripper_base_link">
    <visual>
      <geometry>
        <!-- scaled down -->
        <box size="0.08 0.04 0.02"/>
      </geometry>
      <!-- place box above the joint frame so it doesn't hide wrist_2_link cylinder -->
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <material name="gripper_material"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.08 0.04 0.02"/>
      </geometry>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
    </collision>
  </link>

  <joint name="gripper_base_to_grasp_point" type="fixed">
    <parent link="gripper_base_link"/>
    <child link="grasp_point_link"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
  </joint>

  <link name="grasp_point_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.02"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
  </link>

  <joint name="gripper_base_to_camera" type="fixed">
    <parent link="gripper_base_link"/>
    <origin xyz="0 -0.02 0" rpy="0 0 0"/>
    <child link="camera_link"/>
  </joint>

  <joint name="finger_joint" type="revolute">
    <parent link="gripper_base_link"/>
    <child link="finger_link"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.05" upper="1.65" effort="15" velocity="1.0"/>
  </joint>

  <link name="finger_link">
    <visual>
      <geometry>
        <box size="0.02 0.04 0.02"/>
      </geometry>
      <origin xyz="0 0 0.02" rpy="0 0 0"/> 
      <material name="grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.02 0.04 0.02"/>
      </geometry>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
    </collision>
  </link>

  </robot>